# Required — from your Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — only needed for server-only admin operations that must bypass RLS
# (not used by any code in this repo yet; add if you need it later)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — rate limiting (Upstash Redis, free tier: https://upstash.com)
# Rate limiting is silently disabled (never blocks) if these are unset.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional — error tracking (Sentry, free tier: https://sentry.io)
# Error tracking is silently disabled if this is unset.
# NEXT_PUBLIC_SENTRY_DSN=

# Optional — only needed to upload source maps to Sentry at build time
# (makes stack traces readable; skipped automatically if unset)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
