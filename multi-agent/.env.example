# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Microsoft Graph / OneDrive
# Create an App Registration at https://portal.azure.com → Azure Active Directory → App registrations
# Grant: Files.Read.All (or Files.Read), User.Read — under API permissions
AZURE_CLIENT_ID=your_app_client_id
AZURE_CLIENT_SECRET=your_app_client_secret
AZURE_TENANT_ID=your_tenant_id_or_common
ONEDRIVE_USER_EMAIL=roger@gulfdatahubfzco.ae
ONEDRIVE_FOLDER_NAME=data centers

# Vector store (ChromaDB runs locally by default — no config needed)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# Optional: override models
SUPERVISOR_MODEL=claude-opus-4-8
AGENT_MODEL=claude-sonnet-5
FAST_MODEL=claude-haiku-4-5-20251001
